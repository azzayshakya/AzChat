VITE_FRONT_END_PORT=7000
VITE_APP_VERSION="2.7.0"
VITE_UNDER_DEVELOPMENT=false
APP_DEVELOPER=AZZAYSHAKYA

VITE_API_URL=http://10.229.40.67:7001
VITE_SOCKET_URL=http://10.229.40.67:7001

# VITE_API_URL=http://localhost:8001
# VITE_SOCKET_URL=http://localhost:8001

# Core Features
VITE_FEATURE_DELETE_OWN_MESSAGE=true
VITE_FEATURE_DELETE_FOR_EVERYONE=true
VITE_FEATURE_FILE_UPLOAD=true
VITE_FEATURE_DELETE_CONTACT=true
VITE_FEATURE_GROUP_CHAT=true
VITE_FEATURE_TYPING_INDICATOR=true
VITE_FEATURE_MESSAGE_SEEN_STATUS=true

# Chat Extra Features
VITE_FEATURE_GIFS=true
VITE_FEATURE_EMOJI=true
VITE_FEATURE_TEXT_FORMATTER=true
VITE_FEATURE_FILE_PREVIEW=true


#status feature

# ─── Status feature ───────────────────────────────────────────────────────────

# Maximum number of active statuses a single user can have at one time
VITE_STATUS_MAX_PER_USER=10

# How many hours a status lives before expiring
VITE_STATUS_TTL_HOURS=24

# Maximum characters allowed in a text status
VITE_STATUS_MAX_TEXT_LEN=300

# Maximum image upload size in megabytes
VITE_STATUS_MAX_IMAGE_MB=5

# Maximum characters allowed in a status reply
VITE_STATUS_REPLY_MAX_LEN=200

# How often (milliseconds) the client polls for fresh statuses
# 60000 = 1 minute
VITE_STATUS_POLL_MS=60000